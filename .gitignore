# --- macOS / external filesystem artifacts ---
.DS_Store
._*

# --- Claude Code local state (per-machine, not shared) ---
.claude/settings.local.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.Python
build/
dist/
wheels/
sdist/
develop-eggs/
parts/
var/
.eggs/
*.manifest
*.spec
pip-wheel-metadata/
share/python-wheels/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.python-version

# --- uv ---
# uv.lock IS committed (reproducible builds); the cache is not.
.uv/

# --- Test / coverage artifacts ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.cache/
.tox/
.nox/
.hypothesis/

# --- Type checker / linter caches ---
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# --- Build / packaging ---
*.tar.gz
*.whl

# --- IDE / editors ---
.idea/
.vscode/
*.swp
*.swo
*~
.~lock.*

# --- Local secrets ---
.env
.env.local
.env.*.local
# .env.example is the documented template — keep it tracked even when a
# user's global ~/.gitignore_global ignores .env.* broadly.
!.env.example

# --- Logs ---
*.log
logs/
