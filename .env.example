# =============================================================================
# ez1-mqtt-bridge — example environment configuration
# =============================================================================
# Copy this file to ".env" and fill in the values for your deployment.
# All settings are loaded by pydantic-settings with the prefix "EZ1_BRIDGE_".
# =============================================================================

# --- EZ1 inverter (lokal, ohne Cloud) ---------------------------------------
EZ1_BRIDGE_EZ1_HOST=192.168.3.24
EZ1_BRIDGE_EZ1_PORT=8050

# --- Polling --------------------------------------------------------------
EZ1_BRIDGE_POLL_INTERVAL=20
EZ1_BRIDGE_REQUEST_TIMEOUT=5

# --- MQTT broker ----------------------------------------------------------
EZ1_BRIDGE_MQTT_HOST=192.168.2.10
EZ1_BRIDGE_MQTT_PORT=1883
# Leave the credentials empty for an anonymous broker.
EZ1_BRIDGE_MQTT_USER=
EZ1_BRIDGE_MQTT_PASSWORD=

# Topic root for state, command, and result messages.
EZ1_BRIDGE_MQTT_BASE_TOPIC=ez1
# Home Assistant MQTT auto-discovery prefix.
EZ1_BRIDGE_MQTT_DISCOVERY_PREFIX=homeassistant

# --- Prometheus metrics endpoint -----------------------------------------
EZ1_BRIDGE_METRICS_PORT=9100

# --- Logging --------------------------------------------------------------
# Level: DEBUG | INFO | WARNING | ERROR
EZ1_BRIDGE_LOG_LEVEL=INFO
# Format: json | text | auto (auto = JSON when stdout is non-TTY, text otherwise)
EZ1_BRIDGE_LOG_FORMAT=auto
